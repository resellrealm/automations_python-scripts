# ─────────────────────────────────────────────────
#  Email Auto-Replier — Zoho Mail Configuration
# ─────────────────────────────────────────────────

# ── Zoho Mail Credentials ─────────────────────────
ZOHO_EMAIL=you@yourdomain.com
ZOHO_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# ── Zoho Server Settings ──────────────────────────
# Custom domain (org account) — most likely yours:
ZOHO_IMAP_HOST=imappro.zoho.eu
ZOHO_IMAP_PORT=993
ZOHO_SMTP_HOST=smtppro.zoho.eu
ZOHO_SMTP_PORT=587

# Personal @zoho.com account? Use these instead:
# ZOHO_IMAP_HOST=imap.zoho.eu
# ZOHO_SMTP_HOST=smtp.zoho.eu

# ── Kimi AI ───────────────────────────────────────
AI_API_URL=https://api.moonshot.cn/v1/chat/completions
AI_API_KEY=your_kimi_api_key_here
AI_MODEL=moonshot-v1-8k
AI_TIMEOUT_SECONDS=60

# ── Your Identity ─────────────────────────────────
YOUR_NAME=Your Name
YOUR_ROLE=Assistant
REPLY_TONE=professional and friendly

# ── Polling ───────────────────────────────────────
POLL_INTERVAL_MINUTES=5
MAX_EMAILS_PER_CYCLE=20

# ── Logging ───────────────────────────────────────
LOG_LEVEL=INFO
