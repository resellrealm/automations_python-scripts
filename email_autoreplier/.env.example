# ─────────────────────────────────────────────
#  Email Auto-Replier — Environment Variables
#  Copy this to .env and fill in your values
# ─────────────────────────────────────────────

# ── Kimi AI (your VPS or Moonshot API) ───────
AI_API_URL=https://api.moonshot.cn/v1/chat/completions
AI_API_KEY=your_kimi_api_key_here
AI_MODEL=moonshot-v1-8k
AI_TIMEOUT_SECONDS=60

# ── Gmail OAuth2 ──────────────────────────────
# Get these from Google Cloud Console > APIs > Credentials
GMAIL_CLIENT_ID=your_client_id.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=your_client_secret_here

# ── Your identity (used in AI system prompt) ──
YOUR_NAME=Your Full Name
YOUR_EMAIL=youremail@gmail.com
YOUR_ROLE=Customer Support / Personal Assistant
REPLY_TONE=professional and friendly

# ── Polling settings ──────────────────────────
POLL_INTERVAL_MINUTES=5
MAX_EMAILS_PER_CYCLE=20

# ── Logging ───────────────────────────────────
LOG_LEVEL=INFO
