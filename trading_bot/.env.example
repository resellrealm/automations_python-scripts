# ── Exchange ──────────────────────────────────────
EXCHANGE=binance                    # binance, kraken, coinbase, bybit, okx
API_KEY=your_exchange_api_key
API_SECRET=your_exchange_api_secret

# ── Trading Config ────────────────────────────────
TRADING_PAIRS=BTC/USDT,ETH/USDT    # comma-separated
TIMEFRAME=1h                        # 1m, 5m, 15m, 1h, 4h, 1d
RISK_PER_TRADE_PCT=1.0              # % of portfolio to risk per trade (1% rule)
MAX_OPEN_TRADES=3

# ── Strategy ──────────────────────────────────────
STRATEGY=rsi_ema                    # rsi_ema | macd_bb | combined

# ── Risk Management ───────────────────────────────
STOPLOSS_PCT=2.0                    # % below entry to cut loss
TAKE_PROFIT_PCT=4.0                 # % above entry to take profit
TRAILING_STOP=true                  # trail stop with price

# ── Mode ──────────────────────────────────────────
DRY_RUN=true                        # true = paper trade (no real orders)
LOG_LEVEL=INFO
