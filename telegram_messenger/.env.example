# OpenClaw Telegram Bot — copy this to .env and fill in values

# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Your personal Telegram user ID (get from @userinfobot)
TELEGRAM_USER_ID=123456789

# Kimi AI VPS endpoint (base URL, e.g. http://1.2.3.4:8000/v1)
AI_API_URL=http://YOUR_VPS_IP:PORT/v1

# Kimi API key
AI_API_KEY=your_kimi_api_key

# Kimi model name
KIMI_MODEL=moonshot-v1-8k
