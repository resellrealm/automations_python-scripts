# ── Kalshi API credentials ────────────────────────────────────
# Step 1: Generate RSA key pair:
#   openssl genrsa -out kalshi_private.pem 2048
#   openssl rsa -in kalshi_private.pem -pubout -out kalshi_public.pem
# Step 2: Go to kalshi.com → Account → API Keys → upload kalshi_public.pem
# Step 3: Copy the Key ID shown and paste below

KALSHI_KEY_ID=your_key_id_here
KALSHI_PRIVATE_KEY_PATH=kalshi_private.pem

# ── Optional overrides ────────────────────────────────────────
# KALSHI_API_URL=https://trading-api.kalshi.com/trade-api/v2
