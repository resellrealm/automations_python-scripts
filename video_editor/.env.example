# ─────────────────────────────────────────
#  Video Editor — Environment Variables
#  Copy this to .env and fill in your values
# ─────────────────────────────────────────

# ── Kimi AI (only used for title/hashtag generation) ──
AI_API_URL=https://api.moonshot.cn/v1/chat/completions
AI_API_KEY=your_kimi_api_key_here
AI_MODEL=moonshot-v1-8k

# ── Whisper (local speech-to-text, no API cost) ───────
# Options: tiny, base, small, medium, large
# tiny = fastest, large = most accurate
WHISPER_MODEL=base

# ── Default platform ──────────────────────────────────
# Options: tiktok, instagram_reel, instagram_square, youtube_short
DEFAULT_PLATFORM=tiktok

# ── Caption style ─────────────────────────────────────
CAPTION_FONT_SIZE=60
CAPTION_COLOR=white
CAPTION_STROKE_COLOR=black
CAPTION_STROKE_WIDTH=3
CAPTION_POSITION=bottom        # top | center | bottom

# ── Output ────────────────────────────────────────────
OUTPUT_DIR=output
LOG_LEVEL=INFO
