# ============================================================
# ROOT .env — Single source of truth for all VPS modules
# Copy to .env and fill in your values:
#   cp .env.example .env
#   nano .env
# ============================================================

# ── Telegram (shared by ALL modules) ────────────────────────
# Get bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Your personal Telegram user ID (get from @userinfobot)
TELEGRAM_USER_ID=123456789

# ── Polymarket ───────────────────────────────────────────────
POLY_API_KEY=your_polymarket_api_key
POLY_API_SECRET=your_polymarket_api_secret
POLY_PASSPHRASE=your_polymarket_passphrase
POLY_ADDRESS=your_wallet_address

# ── Kalshi ───────────────────────────────────────────────────
KALSHI_EMAIL=your_kalshi_email
KALSHI_PASSWORD=your_kalshi_password

# ── Apprenticeship Applier ───────────────────────────────────
GOV_EMAIL=your_gov_uk_email
GOV_PASSWORD=your_gov_uk_password

# ── Kimi AI ──────────────────────────────────────────────────
KIMI_API_KEY=your_kimi_api_key

# ── Email (Zoho) ─────────────────────────────────────────────
ZOHO_EMAIL=your_zoho_email
ZOHO_PASSWORD=your_zoho_app_password
