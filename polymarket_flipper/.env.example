# Polymarket CLOB credentials
# Get these from: https://polymarket.com → Settings → API Keys
POLYMARKET_PRIVATE_KEY=0xYOUR_EVM_PRIVATE_KEY
POLYMARKET_API_KEY=your_api_key
POLYMARKET_API_SECRET=your_api_secret
POLYMARKET_API_PASSPHRASE=your_api_passphrase

# API URLs (defaults already set — only change for local proxy)
CLOB_API_URL=https://clob.polymarket.com
GAMMA_API_URL=https://gamma-api.polymarket.com

# Optional: override GBP/USD rate
# GBP_TO_USDC=1.27
