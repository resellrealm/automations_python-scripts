# ── Polymarket / Polygon Wallet ───────────────────
POLYGON_PRIVATE_KEY=0xyour_private_key_here
POLYGON_RPC_URL=https://polygon-rpc.com

# ── Polymarket CLOB API ───────────────────────────
CLOB_HOST=https://clob.polymarket.com
GAMMA_HOST=https://gamma-api.polymarket.com

# ── Kimi AI (for market sentiment) ───────────────
AI_API_URL=https://api.moonshot.cn/v1/chat/completions
AI_API_KEY=your_kimi_api_key
AI_MODEL=moonshot-v1-8k

# ── Strategy ──────────────────────────────────────
# Options: flash_crash | market_maker | arbitrage | ai_sentiment
STRATEGY=flash_crash

# ── Trading Config ────────────────────────────────
MAX_POSITION_USDC=50.0       # max $ per position
MIN_EDGE_PCT=3.0             # minimum edge % to trade
MAX_OPEN_POSITIONS=5
DRY_RUN=true

# ── Flash Crash Strategy ──────────────────────────
FLASH_CRASH_DROP_PCT=15.0    # buy when prob drops this % in 1 candle
FLASH_CRASH_TARGET_PCT=8.0   # sell when prob recovers this %

# ── Market Maker Strategy ─────────────────────────
MM_SPREAD_PCT=3.0            # target bid-ask spread to capture
MM_INVENTORY_LIMIT=100.0     # max $ in YES or NO side

# ── Logging ───────────────────────────────────────
LOG_LEVEL=INFO
