# ──────────────────────────────────────────────────
#  Apprenticeship Applier — Environment Variables
#  Copy this to .env and fill in your values
# ──────────────────────────────────────────────────

# ── Kimi AI (your VPS or Moonshot API) ────────────
AI_API_URL=https://api.moonshot.cn/v1/chat/completions
AI_API_KEY=your_kimi_api_key_here
AI_MODEL=moonshot-v1-8k
AI_TIMEOUT_SECONDS=90

# ── Search filters ────────────────────────────────
SEARCH_KEYWORDS=software,IT,data,technology,developer
SEARCH_LOCATION=London
SEARCH_DISTANCE_MILES=30
# apprenticeship levels: Intermediate,Advanced,Higher,Degree (comma-separated or leave blank for all)
SEARCH_LEVELS=Higher,Degree

# ── Application settings ──────────────────────────
MAX_APPLICATIONS_PER_RUN=10
DRY_RUN=false              # Set to true to scrape + generate letters but NOT submit
HEADLESS=true              # Set to false to see the browser window (useful for debugging)

# ── gov.uk account (needed to apply) ─────────────
GOVUK_EMAIL=youremail@gmail.com
GOVUK_PASSWORD=your_govuk_password

# ── Logging ───────────────────────────────────────
LOG_LEVEL=INFO
