# ──────────────────────────────────────────────────
#  Apprenticeship Applier — Environment Variables
#  Copy this to .env and fill in your values
# ──────────────────────────────────────────────────

# ── Kimi AI ───────────────────────────────────────
AI_API_URL=https://api.moonshot.cn/v1/chat/completions
AI_API_KEY=your_kimi_api_key_here
AI_MODEL=moonshot-v1-8k
AI_TIMEOUT_SECONDS=90

# ── Gov.uk account ────────────────────────────────
GOVUK_EMAIL=georgeb9@protonmail.com
GOVUK_PASSWORD=your_govuk_password_here

# ── Telegram bot ──────────────────────────────────
# 1. Message @BotFather on Telegram → /newbot → copy token
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# 2. Message @userinfobot on Telegram → copy your ID
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ── CAPTCHA solving ───────────────────────────────
# Optional: sign up at 2captcha.com, top up $3, paste key below
# If blank, bot will send you a noVNC link to solve manually
TWOCAPTCHA_API_KEY=
# Your VPS public IP — for the noVNC browser link
VPS_IP=your.vps.ip.address

# ── Job search ────────────────────────────────────
SEARCH_KEYWORDS=finance,accounting,insurance,risk,actuarial,banking,investment,audit,compliance
SEARCH_LOCATION=Brighton
SEARCH_DISTANCE_MILES=60
# Leave blank for all levels, or filter:
SEARCH_LEVELS=Level 3,Level 4,Level 6,Level 7

# ── Application settings ──────────────────────────
MAX_APPLICATIONS_PER_RUN=10
DRY_RUN=false
HEADLESS=true
LOG_LEVEL=INFO
